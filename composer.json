{
    "name": "yiisoft/yii2-apidoc",
    "description": "API Documentation generator for the Yii framework 2.0",
    "keywords": ["yii2", "phpdoc", "apidoc", "api", "documentation"],
    "type": "yii2-extension",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yiisoft/yii2-apidoc/issues",
        "forum": "https://www.yiiframework.com/forum/",
        "wiki": "https://www.yiiframework.com/wiki/",
        "irc": "ircs://irc.libera.chat:6697/yii",
        "source": "https://github.com/yiisoft/yii2-apidoc"
    },
    "authors": [
        {
            "name": "Carsten Brandt",
            "email": "mail@cebe.cc"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "ext-dom": "*",
        "ext-mbstring": "*",
        "php": "^8.2",
        "yiisoft/yii2": "~2.0.16",
        "phpdocumentor/reflection": "7.x-dev",
        "phpdocumentor/type-resolver": "^2.0",
        "nikic/php-parser": "^5.0",
        "cebe/js-search": "~0.9.0",
        "cebe/markdown": "^1.0",
        "cebe/markdown-latex": "^1.0",
        "scrivo/highlight.php": "^9.0"
    },
    "require-dev": {
        "yiisoft/yii2-bootstrap": "~2.0.0",
        "phpunit/phpunit": "^11.5",
        "spatie/phpunit-snapshot-assertions": "^5.0",
        "phpstan/phpstan": "^2.1",
        "yiisoft/yii2-coding-standards": "^3.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "suggest": {
        "ext-json": "for outputting documentation data structures as a JSON text",
        "ext-intl": "for generating slugs in non-English guides",
        "yiisoft/yii2-bootstrap": "for generating API documentation based on the Bootstrap template"
    },
    "autoload": {
        "psr-4": {
            "yii\\apidoc\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "yiiunit\\apidoc\\": "tests/"
        }
    },
    "bin": ["apidoc"],
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "scripts": {
        "cs": "./vendor/bin/phpcs",
        "cs-fix": "./vendor/bin/phpcbf",
        "static": "./vendor/bin/phpstan --memory-limit=-1",
        "tests": "./vendor/bin/phpunit"
    }
}
